# Server
PORT=4000
JWT_SECRET=change-me-to-a-long-random-string

# Database — local dev uses SQLite (node:sqlite, built into Node.js).
# Leave unset to use ./decoory.db. For production, point SQLITE_PATH at a
# persistent disk, or migrate to Supabase Postgres (see README "Deployment").
SQLITE_PATH=

# Supabase (production Postgres + Storage) — optional in local dev
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=decoory-media

# Anthropic (AI budget estimation) — falls back to the rule-based estimator
# in src/services/estimator.js when absent
ANTHROPIC_API_KEY=

# Razorpay (test mode) — when absent, admin gets a "Record payment manually" action instead
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Firebase Cloud Messaging (push notifications)
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=
